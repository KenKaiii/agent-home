{
  "expo": {
    "name": "agent-home",
    "slug": "agent-home",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "agent-home",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "plugins": [
      ["expo-router", { "root": "./src/app" }],
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Agent Home to scan QR codes for pairing"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#58a6ff"
        }
      ]
    ],
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#58a6ff",
      "androidMode": "default",
      "androidCollapsedTitle": "Agent Home"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agenthome.app"
    },
    "android": {
      "package": "com.agenthome.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "relayUrl": "wss://agent-home-relay.buzzbeamaustralia.workers.dev/ws",
      "provisioningSecret": "agent-home-provision-2026"
    }
  }
}
